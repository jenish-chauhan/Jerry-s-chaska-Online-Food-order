# =============================================================================
# Frontend .gitignore — React app
# =============================================================================

# ---------- Dependencies ----------
node_modules/

# ---------- Environment files (contain API keys) ----------
.env
.env.local
.env.*.local

# ---------- Build output ----------
dist/
build/

# ---------- Logs ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- OS files ----------
.DS_Store
Thumbs.db
Desktop.ini

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo
