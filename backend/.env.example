# =============================================================================
# Backend Environment Variables
# =============================================================================
# Copy this file to .env and update with your actual values.
#
# In Kubernetes these values are injected via ConfigMaps and Secrets —
# you do NOT need a .env file inside the container.
# =============================================================================

# ---------- Database Configuration ----------
# DB_HOST must be the Kubernetes Service name for MySQL (e.g. "mysql" or
# "jerrys-mysql"), NOT "localhost". In local development you can use localhost.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=jerrys_chaska

# ---------- Server Configuration ----------
PORT=3000
NODE_ENV=development

# ---------- JWT Configuration ----------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# ---------- CORS Configuration ----------
# In Kubernetes this should be the frontend Service URL or Ingress URL.
FRONTEND_URL=http://localhost:5173
